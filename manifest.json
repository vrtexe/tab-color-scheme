{
  "manifest_version": 3,
  "name": "Tab Color Scheme",
  "short_name": "tab-color-scheme",
  "version": "1.0.0",
  "author": "vrtexe",
  "homepage_url": "https://github.com/vrtexe/tab-color-scheme",
  "description": "Toggle the browser color scheme from the toolbar per tab",
  "icons": {
    "16": "icons/ThemeIcon.svg",
    "32": "icons/ThemeIcon.svg",
    "48": "icons/ThemeIcon.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tab-color-scheme@vrtexe",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "action": {
    "default_icon": {
      "16": "icons/ThemeIcon.svg",
      "32": "icons/ThemeIcon.svg",
      "48": "icons/ThemeIcon.svg"
    },
    "default_title": "Toggle Color Scheme"
  },
  "permissions": ["storage", "browserSettings", "tabs"],
  "background": {
    "scripts": ["main.js"]
  }
}
